{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build qlippy (build.sh)",
			"type": "shell",
			"command": "pkill -f '${workspaceFolder}/qlippy/build/src/app/qlippy' || true; '${workspaceFolder}/qlippy/build.sh' && '${workspaceFolder}/qlippy/build/src/app/qlippy' --daemon",
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Lint QML",
			"type": "shell",
			"command": "cmake --build '${workspaceFolder}/qlippy/build' --target qlippy_ui_qmllint",
			"isBackground": false,
			"problemMatcher": [],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		}
	]
}