[Unit]
Description=qlippy Wayland clipboard manager daemon
Documentation=https://github.com/your-username/qlippy
PartOf=graphical-session.target
After=graphical-session.target

[Service]
ExecStart=%h/.local/bin/qlippy --daemon
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
